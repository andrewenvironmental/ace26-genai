# Public-safe example only. Copy to .env locally and fill in real values.
# Do not commit .env or .env.* files.

AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_SUBSCRIPTION_NAME=
AZURE_LOCATION=westus2
AZURE_AI_SERVICES_LOCATION=eastus2
AZURE_RESOURCE_GROUP=

# Workshop naming. Keep globally unique resource names in local parameter files
# if they identify a real environment.
WORKSHOP_NAME=ace-ai-workshop

# Optional model deployment names used in workshop instructions.
CHAT_DEPLOYMENT_NAME=
EMBEDDING_DEPLOYMENT_NAME=

# Resource names used by infra scripts (Set-WorkshopModelCapacity, Create-FoundryVectorStore, etc.)
AZURE_AI_SERVICES_ACCOUNT=
AZURE_AI_SERVICES_PROJECT=
AZURE_SEARCH_SERVICE=
AZURE_STORAGE_ACCOUNT=

# User identity for RBAC scripts (Print-RequiredRoleAssignments).
AZURE_USER_OBJECT_ID=

# Optional participant/security values. These should stay private.
PARTICIPANT_GROUP_OBJECT_ID=
INSTRUCTOR_GROUP_OBJECT_ID=
